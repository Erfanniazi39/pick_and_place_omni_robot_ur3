<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <!-- Gripper macro for UR3 end effector -->
    <xacro:macro name="gripper" params="name parent *origin">
        
        <!-- Gripper base link -->
        <link name="${name}_base_link">
            <inertial>
                <mass value="0.3"/>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.05 0.08 0.1"/>
                </geometry>
                <material name="gripper_color">
                    <color rgba="0.2 0.2 0.2 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.05 0.08 0.1"/>
                </geometry>
            </collision>
        </link>

        <!-- Fixed joint from tool0 to gripper base -->
        <joint name="${name}_base_joint" type="fixed">
            <parent link="${parent}"/>
            <child link="${name}_base_link"/>
            <xacro:insert_block name="origin"/>
        </joint>

        <!-- Left finger -->
        <link name="${name}_left_finger_link">
            <inertial>
                <mass value="0.05"/>
                <origin xyz="0 0 0.025" rpy="0 0 0"/>
                <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.000005"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0.025" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.02 0.05"/>
                </geometry>
                <material name="finger_color">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0.025" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.02 0.05"/>
                </geometry>
            </collision>
        </link>

        <!-- Right finger -->
        <link name="${name}_right_finger_link">
            <inertial>
                <mass value="0.05"/>
                <origin xyz="0 0 0.025" rpy="0 0 0"/>
                <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.000005"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0.025" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.02 0.05"/>
                </geometry>
                <material name="finger_color">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0.025" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.02 0.05"/>
                </geometry>
            </collision>
        </link>

        <!-- Left finger joint -->
        <joint name="${name}_left_finger_joint" type="prismatic">
            <parent link="${name}_base_link"/>
            <child link="${name}_left_finger_link"/>
            <origin xyz="0 0.025 0.05" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <limit lower="-0.04" upper="0.01" effort="180" velocity="1.0"/>
            <dynamics friction="0.1" damping="1.0"/>
        </joint>

        <!-- Right finger joint - synchronized through controller (no mimic for Gazebo compatibility) -->
        <joint name="${name}_right_finger_joint" type="prismatic">
            <parent link="${name}_base_link"/>
            <child link="${name}_right_finger_link"/>
            <origin xyz="0 -0.025 0.05" rpy="0 0 0"/>
            <axis xyz="0 -1 0"/>
            <limit lower="-0.04" upper="0.01" effort="180" velocity="1.0"/>
            <dynamics friction="0.1" damping="1.0"/>
        </joint>

        <gazebo reference="${name}_left_finger_link">
            <mu1>5.0</mu1>
            <mu2>5.0</mu2>
            <kp>1000000.0</kp>
            <kd>10.0</kd>
            <maxVel>0.05</maxVel>
            <minDepth>0.001</minDepth>
        </gazebo>

        <gazebo reference="${name}_right_finger_link">
            <mu1>5.0</mu1>
            <mu2>5.0</mu2>
            <kp>1000000.0</kp>
            <kd>10.0</kd>
            <maxVel>0.05</maxVel>
            <minDepth>0.001</minDepth>
        </gazebo>

        <!-- Gripper tool link (for grasping objects) -->
        <link name="${name}_tool_link">
            <inertial>
                <mass value="0.001"/>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
            </inertial>
        </link>

        <!-- Tool link at gripper tip -->
        <joint name="${name}_tool_joint" type="fixed">
            <parent link="${name}_base_link"/>
            <child link="${name}_tool_link"/>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
        </joint>

    </xacro:macro>

</robot>
