<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="omni_gz_ros2_control">

		<gazebo>
			<plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
				<parameters>$(find omni_control)/config/omni_controllers.yaml</parameters>
			</plugin>
		</gazebo>

    </xacro:macro>

</robot>